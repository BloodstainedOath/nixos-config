{ config, pkgs, ... }:

{
  fonts = {
    enableDefaultPackages = true;

    packages = with pkgs; [
      nerd-fonts.go-mono
      font-awesome
      nerd-fonts.fira-code
      nerd-fonts.jetbrains-mono
      noto-fonts
      noto-fonts-cjk-serif
      noto-fonts-emoji
      noto-fonts-color-emoji
      nerd-fonts.symbols-only
    ];
  };
}

